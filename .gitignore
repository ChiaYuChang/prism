# Binaries for programs and plugins
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)

# Go workspace file
go.work
go.work.sum

# env file
.env

# logs
*/logs/
logs
journal

# data
data/
_*

# secrets — single broad rule for the env/local/ subtree so any new
# bake-managed or user-managed file added here is excluded automatically;
# avoids the per-file blacklist drift that allowed earlier leaks.
.secrets/
env/local/
.env
.venv
*.pem
*.key
credentials.json

# temporary files
.*.docker-compose.merged.yaml
.docker-compose.merged.yaml
compose-bake
tmp/

# integration test fixtures (rebuild with `go run ./cmd/dev/downloader`)
testdata/fixtures/
**/testdata/fixtures/
testdata/real/

# Editor/IDE
.idea/
.vscode/

# support files
SESSION_SUMMARY.md
CLAUDE.md
AGENTS.md
.task/*
build/ok*
opencode.json
.venv/*
.python-version
pyproject.toml
uv.lock
docs/why

# build infrastructure configs
build/infra/nats/nats.conf
build/infra/otel/otel.yaml
build/infra/valkey/valkey.conf
build/infra/valkey/valkey_acl

# build binaries
bin/
NOTE.md

# coding agents settings
.claude
.agents
.codex

review_report.md
