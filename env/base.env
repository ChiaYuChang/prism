# Cross-environment, non-secret defaults. Committed.
#
# Loading order (root Taskfile.yml dotenv:):
#   env/local/{{.ENV}}.local.env   (gitignored, secrets)
#   env/{{.ENV}}.env               (committed, env-specific defaults; test.env etc.)
#   env/base.env                   (this file)
# Earlier entries win on conflict.

# General
APP_NAME=prism

# Postgres
POSTGRES_PORT=5432
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD_FILE=.secrets/pg-admin
POSTGRES_APP_DB=prism
POSTGRES_APP_USER=prism
POSTGRES_APP_PASSWORD_FILE=.secrets/pg-prism

# Valkey
VALKEY_APP_DB=prism
VALKEY_APP_USER=prism

# NATS
NATS_SERVER_NAME=prism-nats
NATS_CLIENT_PORT=4222
NATS_HTTP_MONITORING_PORT=8222
NATS_AUTH_TOKEN_FILE=.secrets/nats-auth-token
NATS_JS_STORE_DIR=data/nats-js

# SeaweedFS
SEAWEEDFS_S3_REGION=ap-east-2
SEAWEEDFS_ACCESS_KEY_FILE=.secrets/seaweedfs-acc
SEAWEEDFS_SECRET_KEY_FILE=.secrets/seaweedfs-scr
SEAWEEDFS_MASTER_PORT=9333
SEAWEEDFS_S3_PORT=8333

# Ollama
OLLAMA_PORT=11434

# Google APIs (paths only; supply files in .secrets/ to enable)
GEMINI_API_KEY_FILE=.secrets/google/gemini
GCLOUD_API_KEY_FILE=.secrets/google/gcloud
GOOGLE_CSE_ID_FILE=.secrets/google/cse-id

# DevTools
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@prism.com
NATS_UI_PORT=31311

# Monitoring & Logging
VICTORIA_LOGS_PORT=9428
GRAFANA_PORT=3100
